# ─────────────────────────────────────────────────────────────────
#  Ask-the-Web Agent — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...           # Get from: https://console.anthropic.com

# ── Search (at least one required) ───────────────────────────────
TAVILY_API_KEY=tvly-...                # Recommended — https://tavily.com (free tier available)
SERPAPI_KEY=                           # Alternative  — https://serpapi.com

# ── App settings ─────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ── Database (optional — agent works without it) ─────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/askweb

# ── Redis (optional — for response caching) ──────────────────────
REDIS_URL=redis://localhost:6379

# ── Agent behaviour ───────────────────────────────────────────────
MAX_AGENT_ITERATIONS=10
MAX_SEARCH_RESULTS=5
REFLECTION_ENABLED=true
MULTI_AGENT_ENABLED=true

# ── Frontend (Vite) ───────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
