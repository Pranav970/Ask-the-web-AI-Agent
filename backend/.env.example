# ─────────────────────────────────────────────────────────────────────────────
#  Ask-the-Web Agent — backend/.env
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── SEARCH (at least one strongly recommended) ────────────────────────────────
# Tavily is purpose-built for LLM agents — get a free key at https://tavily.com
TAVILY_API_KEY=tvly-REPLACE_ME
# SerpAPI fallback (optional) — https://serpapi.com
SERPAPI_KEY=

# ── APP ───────────────────────────────────────────────────────────────────────
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=text
HOST=0.0.0.0
PORT=8000

# ── CLAUDE MODEL ──────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# ── AGENT BEHAVIOUR ───────────────────────────────────────────────────────────
MAX_AGENT_ITERATIONS=10
MAX_SEARCH_RESULTS=5
REFLECTION_ENABLED=true
MULTI_AGENT_ENABLED=true

# ── DATABASE (optional — app works fully without it) ──────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/askweb
DATABASE_POOL_SIZE=10

# ── REDIS (optional — for caching) ────────────────────────────────────────────
REDIS_URL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your frontend URL if deploying to a different domain
# ALLOWED_ORIGINS=["https://yourdomain.com"]
